{
  "properties": {
    "connectionParameters": {
      "token": {
        "type": "oauthSetting",
        "oAuthSettings": {
          "identityProvider": "oauth2generic",
          "properties": {
            "ItestFirstParty": "true",
            "IsOnbehalfofLoginSupported": false
          },
          "customParameters": {
            "tokenUrlTemplate": {
              "value": "https://hub.onehub.global/oauth2/default/v1/token"
            },
            "tokenBodyTemplate": {
              "value": "grant_type=client_credentials&client_id={clientid}&client_secret={clientSecret}"
            }
          }
        }
      }
    },
    "iconBrandColor": "#007ee5",
    "publisher": "Microsoft"
  }
}