{
  "properties": {
    "connectionParameters": {
      "token": {
        "type": "oauthSetting",
        "oAuthSettings": {
          "identityProvider": "oauth2generic",
          "properties": {
            "ItestirstParty": "true",
            "IsOnbehalfofLoginSupported": false
          },
          "customParameters": {
            "tokenUrlTemplate": {
              "value": "https://qa.benefitsolver.com/benefits/rest/token?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Expires=86400&X-Amz-SignedHeaders=host&X-Amz-Singnature={apiSecret}"
            }
          }
        }
      }
    },
    "iconBrandColor": "#ffa500",
    "publisher": "Microsoft"
  }
}